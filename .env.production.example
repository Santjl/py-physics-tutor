POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=quiz_db

SECRET_KEY=change-this-secret-key
APP_ENV=prod

# Choose providers for production.
LLM_PROVIDER=google
EMBED_PROVIDER=google
RETRIEVAL_PROVIDER=local

# Use either an API key or Google ADC/service-account credentials.
GOOGLE_GENAI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_DISCOVERY_ENGINE_ID=
GOOGLE_DISCOVERY_DATA_STORE_ID=
GOOGLE_DISCOVERY_SERVING_CONFIG=default_search
